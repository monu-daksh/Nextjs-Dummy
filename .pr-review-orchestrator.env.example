# ── Provider selection ────────────────────────────────────────────────
# multi-agent = 6 specialized AI agents (auto-picks best available AI)
# claude | groq | gemini | ollama | openai | local
PR_REVIEW_PROVIDER=multi-agent

# ── Phase 2: Paid AI (enterprise, highest quality) ────────────────────
# Anthropic Claude — best quality, adaptive thinking, scales to any team
# When you add this key, ALL 6 agents automatically upgrade to Claude.
# No code changes needed — just set the key.
# Get API key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-opus-4-6     # best quality
# ANTHROPIC_MODEL=claude-sonnet-4-6   # balanced speed/quality
# ANTHROPIC_MODEL=claude-haiku-4-5    # fastest, cheapest

# ── Phase 1: Free AI (start here — pick one, first with a key wins) ───
# Groq: free tier, Llama 3.3 70B, 14,400 req/day, very fast
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini: free tier, 1M tokens/day
# Get free key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Ollama: local models, completely free, works offline
# Install: https://ollama.com  then: ollama pull llama3.2
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Alternative paid AI ────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# ── GitHub Issues (optional) ──────────────────────────────────────────
# GITHUB_TOKEN=your_github_token_here
# GITHUB_REPOSITORY=owner/repo
# GITHUB_ISSUE_MIN_SEVERITY=high
# GITHUB_ISSUE_LABELS=ai-review,automated
